{
  "datasets": [
    {
      "name": "193f8cdf",
      "displayName": "Ventas Mensuales",
      "queryLines": [
        "SELECT\n",
        "  date_trunc('month', CAST(v.fecha AS DATE)) as mes,\n",
        "  d.categoria,\n",
        "  v.producto,\n",
        "  SUM(v.cantidad) as unidades_vendidas,\n",
        "  SUM(v.cantidad * v.precio) as importe_total,\n",
        "  AVG(v.precio) as precio_medio\n",
        "FROM\n",
        "  sesion_uno.data.productos v\n",
        "    JOIN sesion_uno.data.dim_producto d\n",
        "      ON v.producto = d.nombre_producto\n",
        "WHERE\n",
        "  CAST(v.fecha AS DATE) BETWEEN :fecha_desde AND :fecha_hasta\n",
        "  AND (\n",
        "    :categoria = 'All'\n",
        "    OR d.categoria = :categoria\n",
        "  )\n",
        "GROUP BY\n",
        "  date_trunc('month', CAST(v.fecha AS DATE)),\n",
        "  d.categoria,\n",
        "  v.producto\n",
        "ORDER BY\n",
        "  mes,\n",
        "  categoria,\n",
        "  producto"
      ],
      "parameters": [
        {
          "displayName": "Start Date",
          "keyword": "fecha_desde",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2025-01-01"
                }
              ]
            }
          }
        },
        {
          "displayName": "End Date",
          "keyword": "fecha_hasta",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2025-12-31"
                }
              ]
            }
          }
        },
        {
          "displayName": "Category",
          "keyword": "categoria",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "All"
                }
              ]
            }
          }
        }
      ]
    }
  ],
